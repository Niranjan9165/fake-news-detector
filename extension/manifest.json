{
    "manifest_version": 3,
    "name": "Fake News Detector",
    "version": "1.0",
    "description": "Detects fake news on any webpage!",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Fake News Detector"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost/*",
        "http://127.0.0.1/*"
    ]
}